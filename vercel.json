{
    "version": 2,
    "builds": [
        {
            "src": "index/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50MB"
            }
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/media/(.*)",
            "dest": "/media/$1"
        },
        {
            "src": "/(.*)",
            "dest": "index/wsgi.py"
        }
    ],
    "outputDirectory": "staticfiles",
    "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput && python manage.py migrate"
}
